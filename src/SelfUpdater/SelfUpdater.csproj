<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <!-- Designed to be consumed by single-file / Native AOT apps. -->
    <IsAotCompatible>true</IsAotCompatible>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Doc comments are provided for the API surface that matters; don't fail on
         every member (records, enum cases, ctors) lacking one. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- Package metadata -->
    <PackageId>SelfUpdater</PackageId>
    <Version>0.1.0</Version>
    <Authors>Andy Gocke</Authors>
    <Description>A small, pluggable self-update engine for single-file .NET apps. Checks a version, downloads the matching build, verifies and validates it, then replaces the running executable in place. Where updates come from is pluggable (HTTP manifest, GitHub releases, a directory/share, or a composite of several backends).</Description>
    <PackageTags>self-update;updater;single-file;aot;auto-update</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/agocke/selfupdater</PackageProjectUrl>
    <RepositoryUrl>https://github.com/agocke/selfupdater</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <!-- Build provenance + debugging: SourceLink, deterministic, embedded untracked
         sources, and a snupkg symbol package. ContinuousIntegrationBuild is set by CI. -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="serde" Version="0.12.0" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
